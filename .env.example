# AI服务提供商配置
# 支持的选项:
#   DeepSeek: deepseek_chat, deepseek_reasoner
#   Gemini:   gemini_25_flash, gemini_25_pro, gemini_3_flash, gemini_31_pro, gemini_31_flash_lite
AI_PROVIDER=deepseek_chat

# DeepSeek API配置
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Google Gemini API配置
GEMINI_API_KEY=your_gemini_api_key_here

# 服务器配置
HOST=localhost
PORT=3004

# 聊天室配置
MAX_HISTORY_LENGTH=50
AUTO_CHAT_INTERVAL=5
